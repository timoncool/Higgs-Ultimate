{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Higgs Ultimate",
  "version": "0.2.4",
  "identifier": "com.higgsaudio.studio",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Higgs Ultimate",
        "width": 1280,
        "height": 860,
        "minWidth": 1180,
        "minHeight": 720,
        "resizable": true,
        "minimizable": true,
        "maximizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$DOWNLOAD/**",
          "$DOCUMENT/**",
          "$AUDIO/**",
          "$VIDEO/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": ["resources/engine/*", "resources/higgs-assets/**/*"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "compression": "lzma"
      }
    }
  }
}
